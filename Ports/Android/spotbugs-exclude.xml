<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
    Project-specific SpotBugs exclusions for the Android port.

    Framework-wide conventions are inherited from
    maven/core-unittests/spotbugs-exclude.xml where they apply here too. Everything
    else below is scoped to the specific class (or method) where the pattern comes
    up, so new occurrences still get reported.
    -->

    <!--
    Codename One exposes internal arrays and mutable state on the client side for
    performance; this is an intentional framework-wide convention.
    -->
    <Match><Bug pattern="EI_EXPOSE_REP" /></Match>
    <Match><Bug pattern="EI_EXPOSE_REP2" /></Match>
    <Match><Bug pattern="MS_EXPOSE_REP" /></Match>

    <!--
    Null is preferred over zero-length arrays (framework convention, matches core).
    -->
    <Match><Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" /></Match>

    <!--
    Fail-fast casts rather than explicit instanceof checks — matches the
    framework-wide rationale in core-unittests/spotbugs-exclude.xml.
    -->
    <Match><Bug pattern="BC_UNCONFIRMED_CAST" /></Match>
    <Match><Bug pattern="BC_UNCONFIRMED_CAST_OF_RETURN_VALUE" /></Match>

    <!--
    Locale-sensitive case conversion is not part of the Codename One API.
    -->
    <Match><Bug pattern="DM_CONVERT_CASE" /></Match>

    <!--
    Static writes from instance methods are accepted by the framework (EDT-assumed
    threading model); documented in core-unittests/spotbugs-exclude.xml.
    -->
    <Match><Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" /></Match>

    <!--
    Callouts to overridable methods from constructors are baked into the CN1
    component lifecycle.
    -->
    <Match><Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" /></Match>

    <!--
    Public/protected fields kept for API compatibility.
    -->
    <Match><Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" /></Match>

    <!--
    Native callback statics (e.g. captureCallback in IOSImplementation's Android
    equivalent) are written from native bridge code that SpotBugs cannot see;
    public/protected fields that look unread are reflected on by the build tools.
    -->
    <Match><Bug pattern="URF_UNREAD_FIELD" /></Match>
    <Match><Bug pattern="UUF_UNUSED_FIELD" /></Match>

    <!--
    AndroidImplementation is a large legacy bridge class. Several patterns below
    are scoped to it because the alternatives would require restructuring the
    entire EDT/native boundary.
    -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.AndroidImplementation(\$.*)?" />
        <Or>
            <!-- Threading primitives in the EDT/native bridge. -->
            <Bug pattern="NO_NOTIFY_NOT_NOTIFYALL" />
            <Bug pattern="UW_UNCOND_WAIT" />
            <Bug pattern="NN_NAKED_NOTIFY" />
            <Bug pattern="WA_NOT_IN_LOOP" />
            <Bug pattern="IS2_INCONSISTENT_SYNC" />
            <!-- Static initialization of per-process caches from a known thread. -->
            <Bug pattern="LI_LAZY_INIT_UPDATE_STATIC" />
            <!-- Inner/anonymous class hoisting saves little in hot paths here. -->
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <!-- Anonymous ImageIO subclass with equals() scoped for string-format arg. -->
            <Bug pattern="BC_EQUALS_METHOD_SHOULD_WORK_FOR_ALL_OBJECTS" />
            <!-- Private methods invoked reflectively from native code. -->
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <!-- Switch/instance-of style that's pervasive in the implementation. -->
            <Bug pattern="BC_VACUOUS_INSTANCEOF" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="DB_DUPLICATE_SWITCH_CLAUSES" />
            <Bug pattern="IA_AMBIGUOUS_INVOCATION_OF_INHERITED_OR_OUTER_METHOD" />
            <!-- Defensive stream handling / exception-edge analysis false positives. -->
            <Bug pattern="OS_OPEN_STREAM" />
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
            <!-- Micro-stores / control-flow artefacts. -->
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE" />
            <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
            <Bug pattern="SA_FIELD_DOUBLE_ASSIGNMENT" />
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
            <!-- Build-time constants / singleton factories. -->
            <Bug pattern="MS_SHOULD_BE_FINAL" />
            <Bug pattern="MS_PKGPROTECT" />
            <!-- Numeric boxing in paths dominated by native overhead. -->
            <Bug pattern="DM_NUMBER_CTOR" />
            <!-- Integer arithmetic precision is intentional for graphics math. -->
            <Bug pattern="ICAST_IDIV_CAST_TO_DOUBLE" />
            <Bug pattern="ICAST_INTEGER_MULTIPLY_CAST_TO_LONG" />
        </Or>
    </Match>

    <!-- canExecute returns null when the platform cannot answer (API contract). -->
    <Match>
        <Class name="com.codename1.impl.android.AndroidImplementation" />
        <Method name="canExecute" />
        <Bug pattern="NP_BOOLEAN_RETURN_NULL" />
    </Match>

    <!-- Float equality comparing against a sentinel, not a computed value. -->
    <Match>
        <Class name="com.codename1.impl.android.AndroidImplementation" />
        <Bug pattern="FE_FLOATING_POINT_EQUALITY" />
    </Match>

    <!-- Ignored return values in Android SDK void-ish calls (e.g. File.delete). -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.AndroidImplementation(\$.*)?" />
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
    </Match>

    <!--
    AndroidAsyncView is a graphics pipeline with its own threading model around
    pendingRenderingOperations; the wait/notify usage is intentional.
    -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.AndroidAsyncView(\$.*)?" />
        <Or>
            <Bug pattern="NO_NOTIFY_NOT_NOTIFYALL" />
            <Bug pattern="UW_UNCOND_WAIT" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="BC_UNCONFIRMED_CAST_OF_RETURN_VALUE" />
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
            <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="UUF_UNUSED_FIELD" />
            <!-- DrawStringCache uses identity-then-equals as a perf shortcut. -->
            <Bug pattern="ES_COMPARING_STRINGS_WITH_EQ" />
            <Bug pattern="BC_EQUALS_METHOD_SHOULD_WORK_FOR_ALL_OBJECTS" />
        </Or>
    </Match>

    <!--
    InPlaceEditView synchronizes state across the EDT and the Android UI thread.
    The static fields are set under the instance lock on purpose — switching to
    a class-level lock would reorder the soft-input lifecycle.
    -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.InPlaceEditView(\$.*)?" />
        <Or>
            <Bug pattern="SSD_DO_NOT_USE_INSTANCE_LOCK_ON_SHARED_STATIC_DATA" />
            <Bug pattern="IS2_INCONSISTENT_SYNC" />
            <Bug pattern="LI_LAZY_INIT_STATIC" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
            <Bug pattern="ICAST_IDIV_CAST_TO_DOUBLE" />
        </Or>
    </Match>

    <!--
    Media/audio classes share locks with their underlying native MediaPlayer.
    -->
    <Match>
        <Class name="com.codename1.media.Audio" />
        <Or>
            <Bug pattern="IS2_INCONSISTENT_SYNC" />
            <Bug pattern="UUF_UNUSED_FIELD" />
            <Bug pattern="DM_GC" />
        </Or>
    </Match>
    <Match>
        <Class name="~com\.codename1\.media\.AudioService(\$.*)?" />
        <Or>
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
            <Bug pattern="OS_OPEN_STREAM" />
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
        </Or>
    </Match>
    <Match>
        <Class name="com.codename1.media.BackgroundAudioService" />
        <Bug pattern="UCF_USELESS_CONTROL_FLOW" />
    </Match>

    <!-- Location manager internals use a Play-services callback pattern. -->
    <Match>
        <Class name="~com\.codename1\.location\.AndroidLocationPlayServiceManager(\$.*)?" />
        <Bug pattern="LI_LAZY_INIT_STATIC" />
    </Match>
    <Match>
        <Class name="com.codename1.location.AndroidLocationPlayServiceManager" />
        <Bug pattern="MS_PKGPROTECT" />
    </Match>

    <!--
    Frida detection legitimately terminates the process when tampering is
    detected — DM_EXIT is part of the intended behavior.
    -->
    <Match>
        <Class name="com.codename1.impl.android.FridaDetectionUtil" />
        <Bug pattern="DM_EXIT" />
    </Match>

    <!-- CodenameOneThread.DEFAULT_STACK_SIZE is a tunable reassigned in tests. -->
    <Match>
        <Class name="com.codename1.impl.CodenameOneThread" />
        <Bug pattern="MS_SHOULD_BE_FINAL" />
    </Match>

    <!-- Notifications compat fields kept public for platform reflection. -->
    <Match>
        <Class name="com.codename1.impl.android.compat.app.NotificationCompatWrapper" />
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" />
    </Match>

    <!-- LocalNotificationPublisher reads locale-sensitive ids intentionally. -->
    <Match>
        <Class name="com.codename1.impl.android.LocalNotificationPublisher" />
        <Or>
            <Bug pattern="DM_CONVERT_CASE" />
            <Bug pattern="MS_SHOULD_BE_FINAL" />
        </Or>
    </Match>

    <!--
    Trust modifier intentionally bypasses certificate validation in a narrow
    helper; the unused array return is the API contract.
    -->
    <Match>
        <Class name="com.codename1.impl.android.TrustModifier" />
        <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" />
    </Match>

    <!-- BillingSupport wraps the IAB callback shape required by Google Play. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.BillingSupport(\$.*)?" />
        <Or>
            <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" />
            <Bug pattern="UCF_USELESS_CONTROL_FLOW" />
        </Or>
    </Match>

    <!-- CodenameOneGestures broad catches are part of gesture reflection. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.[A-Za-z0-9_]+" />
        <Bug pattern="REC_CATCH_EXCEPTION" />
    </Match>
    <Match>
        <Class name="~com\.codename1\.location\.[A-Za-z0-9_]+" />
        <Bug pattern="REC_CATCH_EXCEPTION" />
    </Match>

    <!-- Zooz in-app purchase is deprecated but still imported for back-compat. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.ZoozPurchase(\$.*)?" />
        <Or>
            <Bug pattern="BC_UNCONFIRMED_CAST" />
            <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
        </Or>
    </Match>

    <!--
    Social providers reflect sign-in state through SDK objects; getSignInAccount
    is effectively non-null when isSuccess() is true, but SpotBugs can't see
    that. Anonymous runnables are bound to the outer sign-in state.
    -->
    <Match>
        <Class name="~com\.codename1\.social\..*" />
        <Or>
            <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
        </Or>
    </Match>

    <!-- Stack-dump helper intentionally retains the underlying stream; used on crash. -->
    <Match>
        <Class name="com.codename1.impl.CodenameOneThread" />
        <Method name="getStack" />
        <Bug pattern="OS_OPEN_STREAM" />
    </Match>

    <!-- Frida tamper check opens /proc entries; leaking on the failure path is fine. -->
    <Match>
        <Class name="com.codename1.impl.android.FridaDetectionUtil" />
        <Bug pattern="OS_OPEN_STREAM" />
    </Match>

    <!-- isDarkMode returns null when the platform cannot answer (API contract). -->
    <Match>
        <Class name="com.codename1.impl.android.AndroidImplementation" />
        <Method name="isDarkMode" />
        <Bug pattern="NP_BOOLEAN_RETURN_NULL" />
    </Match>

    <!-- setActivity / setViewAboveBelow / writeServiceProperties accept external state by reference. -->
    <Match>
        <Class name="com.codename1.impl.android.AndroidImplementation" />
        <Or>
            <Method name="setActivity" />
            <Method name="setViewAboveBelow" />
            <Method name="writeServiceProperties" />
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_STATIC_REP2" />
            <Bug pattern="WMI_WRONG_MAP_ITERATOR" />
        </Or>
    </Match>

    <!-- NativeFont compares float pixel sizes using ==; intentional exact match. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.AndroidImplementation\$NativeFont" />
        <Bug pattern="FE_FLOATING_POINT_EQUALITY" />
    </Match>

    <!--
    Billing/Intent/Push helpers use anonymous classes tied to the outer class for
    state access; scoping them static would require extracting fields the SDK
    passes at runtime.
    -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.BillingSupport(\$.*)?" />
        <Or>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
        </Or>
    </Match>
    <Match>
        <Class name="~com\.codename1\.impl\.android\.IntentIntegrator(\$.*)?" />
        <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
    </Match>
    <Match>
        <Class name="~com\.codename1\.impl\.android\.PushNotificationService(\$.*)?" />
        <Or>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
        </Or>
    </Match>

    <!-- AndroidGraphics division-for-gradient and default-less switches are fine. -->
    <Match>
        <Class name="com.codename1.impl.android.AndroidGraphics" />
        <Or>
            <Bug pattern="ICAST_IDIV_CAST_TO_DOUBLE" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!--
    AndroidContactsManager / AndroidDB wrap the Android SDK cursor APIs; the DLS
    and redundant null-check findings come from cursor-read patterns.
    -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.(AndroidContactsManager|AndroidDB)(\$.*)?" />
        <Or>
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
        </Or>
    </Match>

    <!-- CodenameOneActivity / CodenameOneView use anonymous dialog/runnable helpers. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.CodenameOneActivity(\$.*)?" />
        <Or>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
        </Or>
    </Match>
    <Match>
        <Class name="~com\.codename1\.impl\.android\.CodenameOneView(\$.*)?" />
        <Or>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!-- AndroidAsyncView pool methods are invoked via generated accessors. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.AndroidAsyncView(\$.*)?" />
        <Or>
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
        </Or>
    </Match>

    <!-- InPlaceEditView remaining style/perf patterns. -->
    <Match>
        <Class name="~com\.codename1\.impl\.android\.InPlaceEditView(\$.*)?" />
        <Or>
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
        </Or>
    </Match>

    <!-- Location helpers spawn anonymous listeners bound to Play-services callbacks. -->
    <Match>
        <Class name="~com\.codename1\.location\..*" />
        <Or>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!-- Media/audio classes use anonymous runnables around SDK MediaPlayer. -->
    <Match>
        <Class name="~com\.codename1\.media\..*" />
        <Or>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="REC_CATCH_EXCEPTION" />
        </Or>
    </Match>
</FindBugsFilter>
