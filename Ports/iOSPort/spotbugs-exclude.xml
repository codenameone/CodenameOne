<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
    Project-specific SpotBugs exclusions for the iOS port.

    The iOS port runs on ParparVM and drives Objective-C natives. Many of the
    findings here stem from native-bridge code that SpotBugs cannot follow; each
    block below is scoped to the specific class (or method) it applies to.
    -->

    <!-- Framework-wide conventions; see core-unittests/spotbugs-exclude.xml. -->
    <Match><Bug pattern="EI_EXPOSE_REP" /></Match>
    <Match><Bug pattern="EI_EXPOSE_REP2" /></Match>
    <Match><Bug pattern="EI_EXPOSE_STATIC_REP2" /></Match>
    <Match><Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" /></Match>
    <Match><Bug pattern="BC_UNCONFIRMED_CAST" /></Match>
    <Match><Bug pattern="DM_CONVERT_CASE" /></Match>
    <Match><Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" /></Match>
    <Match><Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" /></Match>

    <!--
    IOSImplementation is a very large class that mediates between CN1 and ParparVM.
    Several patterns below are scoped to it because fixing them properly would
    require restructuring the native bridge.
    -->
    <Match>
        <Class name="~com\.codename1\.impl\.ios\.IOSImplementation(\$.*)?" />
        <Or>
            <!-- Threading primitives around the native run loop. -->
            <Bug pattern="NO_NOTIFY_NOT_NOTIFYALL" />
            <Bug pattern="UW_UNCOND_WAIT" />
            <Bug pattern="NN_NAKED_NOTIFY" />
            <Bug pattern="WA_NOT_IN_LOOP" />
            <Bug pattern="IS2_INCONSISTENT_SYNC" />
            <Bug pattern="DL_SYNCHRONIZATION_ON_SHARED_CONSTANT" />
            <!-- Callbacks written from native code; SpotBugs sees them as lazy-init. -->
            <Bug pattern="LI_LAZY_INIT_STATIC" />
            <!-- Private methods invoked via ParparVM's native layer. -->
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="URF_UNREAD_FIELD" />
            <Bug pattern="UUF_UNUSED_FIELD" />
            <!-- Inner/anonymous classes match the native callback shape. -->
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="BC_EQUALS_METHOD_SHOULD_WORK_FOR_ALL_OBJECTS" />
            <Bug pattern="NP_EQUALS_SHOULD_HANDLE_NULL_ARGUMENT" />
            <!-- Switch/cast artefacts in the long implementation file. -->
            <Bug pattern="BC_VACUOUS_INSTANCEOF" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="DB_DUPLICATE_SWITCH_CLAUSES" />
            <!-- Null-analysis artefacts on native-returning paths. -->
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE" />
            <Bug pattern="DCN_NULLPOINTER_EXCEPTION" />
            <!-- Micro-stores that SpotBugs flags on generated-shaped code. -->
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <!-- Numeric boxing inside boxed-arg JNI paths. -->
            <Bug pattern="DM_NUMBER_CTOR" />
            <!-- Float equality is intentional against sentinel values. -->
            <Bug pattern="FE_FLOATING_POINT_EQUALITY" />
            <!-- Static tuning constants are modifiable by tests. -->
            <Bug pattern="MS_SHOULD_BE_FINAL" />
            <!-- ImageIO implementation resource-close analysis is noisy. -->
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
        </Or>
    </Match>

    <!-- canExecute / isDarkMode return null when the platform cannot answer (API contract). -->
    <Match>
        <Class name="com.codename1.impl.ios.IOSImplementation" />
        <Or>
            <Method name="canExecute" />
            <Method name="isDarkMode" />
        </Or>
        <Bug pattern="NP_BOOLEAN_RETURN_NULL" />
    </Match>

    <!-- Purchase is a deprecated Zooz-era flow; fields are populated by native code. -->
    <Match>
        <Class name="~com\.codename1\.impl\.ios\.ZoozPurchase(\$.*)?" />
        <Or>
            <Bug pattern="UWF_NULL_FIELD" />
            <Bug pattern="SSD_DO_NOT_USE_INSTANCE_LOCK_ON_SHARED_STATIC_DATA" />
            <Bug pattern="NN_NAKED_NOTIFY" />
            <Bug pattern="NO_NOTIFY_NOT_NOTIFYALL" />
            <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" />
        </Or>
    </Match>

    <!-- IOSVirtualKeyboard stores the CN1 virtual keyboard reference by design. -->
    <Match>
        <Class name="com.codename1.impl.ios.IOSVirtualKeyboard" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>

    <!--
    TextEditUtil holds editor state in package-visible statics for the native
    bridge; keeping them private-static with accessors would require reworking
    the native callbacks.
    -->
    <Match>
        <Class name="com.codename1.impl.ios.TextEditUtil" />
        <Or>
            <Bug pattern="MS_PKGPROTECT" />
            <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" />
        </Or>
    </Match>

    <!--
    finalize() on native-backed classes (NSData, NSFileInputStream, etc.) is
    public on purpose so the native layer can invoke it.
    -->
    <Match><Bug pattern="FI_PUBLIC_SHOULD_BE_PROTECTED" /></Match>

    <!-- NSFileInputStream shadowing int reads: SpotBugs sees dead stores. -->
    <Match>
        <Class name="com.codename1.impl.ios.NSFileInputStream" />
        <Bug pattern="DLS_DEAD_LOCAL_STORE" />
    </Match>

    <!-- IOSNative is an opaque native-bridge facade. -->
    <Match>
        <Class name="com.codename1.impl.ios.IOSNative" />
        <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" />
    </Match>

    <!-- Social provider impls get auth state through native SDK callbacks. -->
    <Match>
        <Class name="~com\.codename1\.social\.(Facebook|Google)Impl(\$.*)?" />
        <Bug pattern="EI_EXPOSE_STATIC_REP2" />
    </Match>
</FindBugsFilter>
