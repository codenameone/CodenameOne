<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor xsi:schemaLocation="https://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0 http://maven.apache.org/xsd/archetype-descriptor-1.1.0.xsd" name="cn1lib"
    xmlns="https://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <requiredProperties>
    <requiredProperty key="cn1Version">
      <defaultValue>8.0-SNAPSHOT</defaultValue>
    </requiredProperty>
    <requiredProperty key="cn1PluginVersion">
      <defaultValue>8.0-SNAPSHOT</defaultValue>
    </requiredProperty>
    <requiredProperty key="kotlinVersion">
      <defaultValue>1.3.72</defaultValue>
    </requiredProperty>
    <requiredProperty key="javaVersion">
      <!-- Same auto-detection as cn1app-archetype: "auto" lets the
           archetype-post-generate.groovy resolve to 17 when running on
           a JDK >= 17 and to 8 otherwise. Passing -DjavaVersion=8/=17
           still wins. -->
      <defaultValue>auto</defaultValue>
    </requiredProperty>

  </requiredProperties>

  <fileSets>
    <fileSet filtered="false" encoding="UTF-8">
      <directory>.idea</directory>
      <includes>
        <include>**</include>
      </includes>
    </fileSet>
  </fileSets>




  <modules>

    <module id="${rootArtifactId}-common" dir="common" name="${rootArtifactId}-common">
      <fileSets>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
          <directory>src/main/java</directory>
          <includes>
            <include>**/*.java</include>
          </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
          <directory>src/main/css</directory>
          <includes>
            <include>**/*.txt</include>
          </includes>
        </fileSet>
        <fileSet filtered="false" encoding="UTF-8">
          <directory>src/main/resources</directory>
          <includes>
            <include>**</include>
          </includes>
        </fileSet>
        <fileSet encoding="UTF-8">
          <directory>src/main/css</directory>
          <includes>
            <include>**/*.css</include>
          </includes>
        </fileSet>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
          <directory>src/test/java</directory>
          <includes>
            <include>**/*.java</include>
          </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
          <directory></directory>
          <includes>
            <include>codenameone_library_required.properties</include>
            <include>codenameone_library_appended.properties</include>
          </includes>
        </fileSet>
      </fileSets>
    </module>
    <module id="${rootArtifactId}-javase" dir="javase" name="${rootArtifactId}-javase">
      <fileSets>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
          <directory>src/main/java</directory>
          <includes>
            <include>**/*.java</include>
          </includes>
        </fileSet>
      </fileSets>
    </module>
    <module id="${rootArtifactId}-javascript" dir="javascript" name="${rootArtifactId}-javascript">
      <fileSets>
        <fileSet encoding="UTF-8">
          <directory>src/main/javascript</directory>
          <includes>
            <include>**/*.js</include>
          </includes>
        </fileSet>
      </fileSets>
    </module>
    <module id="${rootArtifactId}-ios" dir="ios" name="${rootArtifactId}-ios">
      <fileSets>
        <fileSet encoding="UTF-8">
          <directory>src/main/objectivec</directory>
          <includes>
            <include>**/*.h</include>
            <include>**/*.m</include>
          </includes>
        </fileSet>
      </fileSets>
    </module>
    <module id="${rootArtifactId}-win" dir="win" name="${rootArtifactId}-win">
      <fileSets>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
          <directory>src/main/c</directory>
          <includes>
            <include>**/*.c</include>
            <include>**/*.h</include>
          </includes>
        </fileSet>
      </fileSets>
    </module>
    <module id="${rootArtifactId}-android" dir="android" name="${rootArtifactId}-android">
      <fileSets>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
          <directory>src/main/java</directory>
          <includes>
            <include>**/*.java</include>
          </includes>
        </fileSet>
      </fileSets>
    </module>
    <module id="${rootArtifactId}-lib" dir="lib" name="${rootArtifactId}-lib" />
  </modules>
</archetype-descriptor>
