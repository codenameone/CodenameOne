<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
    Project-specific SpotBugs exclusions for the Maven plugin.

    The plugin wraps a lot of external processes (gradle/xcode/zip), hosts Mojo
    entry points whose fields are reflectively injected by Maven, and vendors a
    JDom-based pom model plus a jtar copy. Exclusions below are scoped to the
    specific package/class where each pattern lives, with the rationale stated
    inline so new occurrences still get flagged.
    -->

    <!-- Framework-wide conventions; see core-unittests/spotbugs-exclude.xml. -->
    <Match><Bug pattern="EI_EXPOSE_REP" /></Match>
    <Match><Bug pattern="EI_EXPOSE_REP2" /></Match>
    <Match><Bug pattern="MS_EXPOSE_REP" /></Match>
    <Match><Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" /></Match>
    <Match><Bug pattern="DM_CONVERT_CASE" /></Match>

    <!--
    Vendored 3rd-party code: org.apache.maven.model.jdom (forked pom model) and
    org.xeustechnologies.jtar. We intentionally don't refactor these.
    -->
    <Match>
        <Class name="~org\.apache\.maven\.model\.jdom\..*" />
    </Match>
    <Match>
        <Class name="~org\.xeustechnologies\.jtar\..*" />
    </Match>

    <!-- Builders package: the native build scripts pattern. -->

    <!--
    The builders orchestrate external commands. File.delete/mkdir/renameTo return
    booleans we don't check because the subsequent command would fail anyway,
    and we broadly catch Exception so the build error surfaces through the
    builder log rather than a stack trace.
    -->
    <Match>
        <Class name="~com\.codename1\.builders\..*" />
        <Or>
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
            <Bug pattern="REC_CATCH_EXCEPTION" />
            <Bug pattern="OS_OPEN_STREAM" />
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
            <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="SE_NO_SERIALVERSIONID" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
            <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION" />
            <Bug pattern="WMI_WRONG_MAP_ITERATOR" />
            <!-- classloader isolation for build classpaths. -->
            <Bug pattern="DP_CREATE_CLASSLOADER_INSIDE_DO_PRIVILEGED" />
            <Bug pattern="UI_INHERITANCE_UNSAFE_GETRESOURCE" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="URF_UNREAD_FIELD" />
            <Bug pattern="UC_USELESS_OBJECT" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="RR_NOT_CHECKED" />
        </Or>
    </Match>

    <!--
    Executor shares state with the stream-pump threads; logger visibility is
    single-writer by construction but SpotBugs only sees 90% locked.
    -->
    <Match>
        <Class name="~com\.codename1\.builders\.Executor(\$.*)?" />
        <Or>
            <Bug pattern="IS2_INCONSISTENT_SYNC" />
            <Bug pattern="UW_UNCOND_WAIT" />
            <Bug pattern="WA_NOT_IN_LOOP" />
            <Bug pattern="NO_NOTIFY_NOT_NOTIFYALL" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
        </Or>
    </Match>

    <!-- AndroidGradleBuilder generates gradle projects with many template-driven String concats. -->
    <Match>
        <Class name="com.codename1.builders.AndroidGradleBuilder" />
        <Or>
            <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE" />
            <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
            <Bug pattern="RV_CHECK_FOR_POSITIVE_INDEXOF" />
            <Bug pattern="UC_USELESS_OBJECT" />
            <Bug pattern="MS_PKGPROTECT" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
        </Or>
    </Match>

    <!-- IPhoneBuilder uses hard-coded system paths intentionally to match Xcode. -->
    <Match>
        <Class name="com.codename1.builders.IPhoneBuilder" />
        <Or>
            <Bug pattern="DMI_HARDCODED_ABSOLUTE_FILENAME" />
            <Bug pattern="RV_CHECK_FOR_POSITIVE_INDEXOF" />
            <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
        </Or>
    </Match>

    <!-- BuildRequest stores raw user inputs; the double-assign is a guard pattern. -->
    <Match>
        <Class name="com.codename1.builders.BuildRequest" />
        <Or>
            <Bug pattern="SA_LOCAL_DOUBLE_ASSIGNMENT" />
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
        </Or>
    </Match>

    <!-- Bundled Base64 helper. -->
    <Match>
        <Class name="com.codename1.builders.Base64" />
        <Bug pattern="SF_SWITCH_NO_DEFAULT" />
    </Match>

    <!-- JSONParser is a vendored parser used by the build log formatter. -->
    <Match>
        <Class name="~com\.codename1\.builders\.util\.JSONParser(\$.*)?" />
        <Or>
            <Bug pattern="BC_BAD_CAST_TO_CONCRETE_COLLECTION" />
            <Bug pattern="DM_FP_NUMBER_CTOR" />
            <Bug pattern="DM_NUMBER_CTOR" />
        </Or>
    </Match>

    <!-- Maven Mojos: fields are reflectively populated by Maven. -->
    <Match>
        <Class name="~com\.codename1\.maven\..*" />
        <Or>
            <!-- Mojo/component fields are injected, not constructed. -->
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
            <Bug pattern="URF_UNREAD_FIELD" />
            <Bug pattern="UUF_UNUSED_FIELD" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <!-- Build-time utilities: stream/exception edges. -->
            <Bug pattern="OS_OPEN_STREAM" />
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
            <!-- Broad catches when invoking external tools. -->
            <Bug pattern="REC_CATCH_EXCEPTION" />
            <!-- Ignored returns on delete/mkdir/close in build scaffolding. -->
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
            <!-- Classloader construction for plugin isolation. -->
            <Bug pattern="DP_CREATE_CLASSLOADER_INSIDE_DO_PRIVILEGED" />
            <!-- Null-analysis artefacts on deeply nested JDom/JDK call graphs. -->
            <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <!-- Serializable exception classes without explicit UID. -->
            <Bug pattern="SE_NO_SERIALVERSIONID" />
            <!-- Non-hot paths that use keySet iteration. -->
            <Bug pattern="WMI_WRONG_MAP_ITERATOR" />
            <!-- Anonymous helpers for Plexus/Maven SPIs. -->
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON" />
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
            <!-- ClassLoader/Resource lookups on the Mojo (context-dependent). -->
            <Bug pattern="UI_INHERITANCE_UNSAFE_GETRESOURCE" />
        </Or>
    </Match>

    <!-- AbstractCN1Mojo constants are tunable via subclasses. -->
    <Match>
        <Class name="com.codename1.maven.AbstractCN1Mojo" />
        <Or>
            <Bug pattern="MS_SHOULD_BE_FINAL" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!-- InstallCn1libsMojo / OpenGuiBuilderMojo control-flow patterns. -->
    <Match>
        <Class name="com.codename1.maven.InstallCn1libsMojo" />
        <Bug pattern="UCF_USELESS_CONTROL_FLOW" />
    </Match>
    <Match>
        <Class name="com.codename1.maven.OpenGuiBuilderMojo" />
        <Bug pattern="RR_NOT_CHECKED" />
    </Match>

    <!-- Value classes used inside the bytecode compliance analyzer. -->
    <Match>
        <Class name="~com\.codename1\.maven\.BytecodeComplianceMojo(\$.*)?" />
        <Or>
            <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS" />
            <Bug pattern="EQ_SELF_USE_OBJECT" />
            <Bug pattern="HE_EQUALS_USE_HASHCODE" />
        </Or>
    </Match>

    <!-- RichPropertiesReader wraps a properties file with helper lookups. -->
    <Match>
        <Class name="com.codename1.util.RichPropertiesReader" />
        <Or>
            <Bug pattern="RV_CHECK_FOR_POSITIVE_INDEXOF" />
            <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE" />
        </Or>
    </Match>
</FindBugsFilter>
