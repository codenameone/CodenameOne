schema {
    query: Query
}

type Query {
    products: [Product!]!
    product(id: ID!): Product
    productsByCategory(category: Category!): [Product!]!
}

type Product {
    id: ID!
    name: String!
    category: Category!
    tags: [String!]!
    rating: Float!
    dimensions: Dimensions
}

type Dimensions {
    width: Float!
    height: Float!
}

enum Category {
    BOOKS
    ELECTRONICS
    TOYS
}
