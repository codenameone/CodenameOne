# Dense vector triangle grid with run-to-run anti-aliasing jitter that
# straddles the tightened 0.05% pipeline gate (flapped with fresh pixels on
# a rerun while every other screen matched -- same family as
# chart-rotated-pie and chart-transform). Keep the pre-tightening gate for
# this screen only; a real regression still moves far more than 0.30%.
maxChannelDelta=4
maxMismatchPercent=0.30
