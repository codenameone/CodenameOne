# tvOS 4K FLAT (non-glass) tile: no backdrop-blur here, so none of the
# run-to-run GPU glass noise that forces the lax glass gate -- hold it tight.
# channelDelta 24 clears cross-runner text anti-aliasing while still catching a
# real recolor or a border/shape change (e.g. square-vs-rounded cell borders);
# mismatch 0.30% (~25k px of 8.3M) fails on any genuine structural drift.
maxChannelDelta=24
maxMismatchPercent=0.30
