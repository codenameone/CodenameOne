# tvOS renders the Liquid Glass surfaces (backdrop blur) with small run-to-run
# GPU noise (channel deltas up to ~40 across the glass area); the default
# channelDelta=4 gate can never settle on these. Real regressions still flag:
# anything past the noise band or moving >1% of pixels fails.
maxChannelDelta=48
maxMismatchPercent=1.0
