# Deterministic offline web-map page (WebMapProvider -> BrowserComponent with a
# fixed, self-contained HTML document: solid-colour land/water/road/park blocks,
# no network, no fonts, no images, no animation). The render is byte-stable per
# backend, so this is a small tolerance covering only WebKit edge anti-aliasing
# / cross-runner-GPU compositing variance. A blank or un-composited web peer --
# the regression this guards -- still differs across essentially the whole frame.
maxChannelDelta=16
maxMismatchPercent=3.0
