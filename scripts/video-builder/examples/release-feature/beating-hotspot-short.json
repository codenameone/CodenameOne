        {"type": "text.show", "id": "short-tagged-title", "atMs": 0, "text": "Boxing without allocation", "uiid": "VideoTitle", "responsive": true, "maxLines": 2, "bounds": {"x": 0.08, "y": 0.02, "width": 0.84, "height": 0.10}},
