    {
      "id": "short-proof",
      "durationMs": 16000,
      "narration": {
        "text": "The harness alternated both runtimes on the same M two and rejected mismatched checksums. String building finished at point six seven. Recursion still lost at one point six. The average is parity, not universal victory."
      },
      "actions": [
        {"type": "svg.show", "id": "short-benchmark", "atMs": 100, "path": "hotspot-bench-portrait.svg", "bounds": {"x": 0.06, "y": 0.06, "width": 0.88, "height": 0.88}},
        {"type": "transition", "target": "short-benchmark", "atMs": 100, "durationMs": 650, "effect": "morph", "easing": "ease-in-out"}
      ]
    },
    {
      "id": "short-frameless",
      "durationMs": 17000,
      "narration": {
        "text": "First, generated methods stopped publishing every local through a G C visible frame. Plain C locals let clang keep values in registers. Recursion improved from seven point six times slower to one point six."
      },
      "actions": [
        {"type": "text.show", "id": "short-frame-title", "atMs": 0, "text": "Let clang see ordinary C", "uiid": "VideoTitle", "responsive": true, "maxLines": 2, "bounds": {"x": 0.08, "y": 0.02, "width": 0.84, "height": 0.10}},
        {"type": "code.show", "id": "short-frame-code", "atMs": 0, "language": "c", "path": "hotspot-frameless.c.txt", "bounds": {"x": 0.05, "y": 0.13, "width": 0.90, "height": 0.43}},
