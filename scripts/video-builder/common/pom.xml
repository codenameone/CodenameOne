<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.codenameone.videobuilder</groupId>
        <artifactId>cn1-video-builder</artifactId>
        <version>8.0-SNAPSHOT</version>
    </parent>
    <artifactId>cn1-video-builder-common</artifactId>
    <name>cn1-video-builder-common</name>
    <description>Timeline, rendering, audio, and automation engine.</description>
    <dependencies>
        <dependency>
            <groupId>com.codenameone</groupId>
            <artifactId>codenameone-core</artifactId>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.2</version>
            <scope>test</scope>
        </dependency>
    </dependencies>
    <build>
        <resources>
            <resource><directory>src/main/resources</directory></resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration><release>17</release></configuration>
            </plugin>
            <plugin>
                <groupId>com.codenameone</groupId>
                <artifactId>codenameone-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>compile-css</id>
                        <phase>process-classes</phase>
                        <goals><goal>css</goal></goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
