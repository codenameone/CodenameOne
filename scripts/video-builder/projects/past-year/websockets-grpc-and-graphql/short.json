      "id": "short-problem",
      "durationMs": 33000,
      "narration": {
        "text": "WebSockets used to require the cn1-websockets cn1lib. They are now part of the framework as com.codename1.io.WebSocket, implemented natively on every port (a hand-rolled RFC 6455 handshake on JavaSE and Android, NSURLSessionWebSocketTask on iOS, the browser WebSocket on JavaScript), with no third-party dependencies pulled into your build."
      },
      "actions": [
        {
          "type": "bullets.show",
          "id": "short-problem-bullets",
          "atMs": 100,
          "durationMs": 2700,
          "title": "Part 1: WebSockets, no cn1lib required",
