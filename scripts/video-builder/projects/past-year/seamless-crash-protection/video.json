    "humanBeat": "A developer receives a production crash from a device they do not own and needs enough evidence to fix it without asking the user to reproduce the failure.",
    "visualIdentity": "An opaque crash address passes through local storage, privacy scrubbing, cloud symbols, and lands as one readable GitHub issue.",
    "bespokeVisualization": "The crash path visibly improves the evidence at each stage while preserving delivery through retries.",
    "heroJourney": {
      "identity": "Codename One and production crash triage are introduced.",
      "problem": "Native addresses, obfuscated names, unreliable networks, and duplicate email make real crashes hard to act on.",
      "difficulty": "Useful symbols live with the build, reports may contain personal data, and the app may die before a network send finishes.",
      "intervention": "The client stores and scrubs first; the build cloud symbolicates; GitHub receives a deduplicated issue.",
      "victory": "The developer opens one issue with platform, version, occurrence count, fingerprint, and a readable stack."
    },
    "problemDimensions": [
      "opaque native stacks",
      "crash-time network failure",
      "privacy and duplicate triage"
    ],
