      "id": "short-problem",
      "durationMs": 19500,
      "narration": {
        "text": "The public API lives in com.codename1.ads. AdManager is the entry point, and there is a type per format: InterstitialAd, RewardedAd, RewardedInterstitialAd, AppOpenAd, BannerAd, and NativeAdLoader."
      },
      "actions": [
        {
          "type": "bullets.show",
          "id": "short-problem-bullets",
          "atMs": 100,
          "durationMs": 2700,
          "title": "One API, every format",
          "items": [
            "Pluggable by design",
            "AdMob as the reference provider",
            "Debugging Ads"
          ],
          "bounds": {
            "x": 0.025,
            "y": 0.05,
            "width": 0.95,
            "height": 0.88
          },
          "orientation": {
