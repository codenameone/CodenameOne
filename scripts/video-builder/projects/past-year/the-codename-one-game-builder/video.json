    "humanBeat": "A developer has sprites, physics, input, and sound, but still cannot judge a level until dozens of object coordinates compile and run.",
    "visualIdentity": "A wall of object setters collapses into one plain game file that fans out into platformer, board, and dungeon scenes.",
    "bespokeVisualization": "The same data model visibly serves three kinds of game while a separate Java lane carries only application behavior.",
    "heroJourney": {
      "identity": "Codename One and visual game authoring are introduced.",
      "problem": "A portable runtime still leaves levels invisible when every object is created and positioned in code.",
      "difficulty": "Different game types need layers, assets, properties, projections, terrain, preview, and eventually streaming worlds.",
      "intervention": "Game Builder edits one plain scene model and generates companion bindings for the runtime.",
      "victory": "The developer draws 2D, board, or 3D levels, reviews them as data, and keeps Java focused on the rules."
    },
    "problemDimensions": [
      "invisible authoring loop",
      "different game modes",
      "large-world memory"
    ],
