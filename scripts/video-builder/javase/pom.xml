<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.codenameone.videobuilder</groupId>
        <artifactId>cn1-video-builder</artifactId>
        <version>8.0-SNAPSHOT</version>
    </parent>
    <groupId>com.codenameone</groupId>
    <artifactId>codenameone-video-builder</artifactId>
    <name>codenameone-video-builder</name>
    <description>JavaSE launcher for the Codename One Video Builder.</description>
    <properties>
        <codename1.platform>javase</codename1.platform>
        <codename1.projectPlatform>javase</codename1.projectPlatform>
    </properties>
    <dependencies>
        <dependency>
            <groupId>com.codenameone.videobuilder</groupId>
            <artifactId>cn1-video-builder-common</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.codenameone.videobuilder</groupId>
            <artifactId>cn1-video-builder-demos</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.codenameone</groupId>
            <artifactId>codenameone-core</artifactId>
        </dependency>
        <dependency>
            <groupId>com.codenameone</groupId>
            <artifactId>codenameone-javase</artifactId>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.2</version>
            <scope>test</scope>
        </dependency>
    </dependencies>
    <build>
        <sourceDirectory>${project.basedir}/src/desktop/java</sourceDirectory>
        <resources>
            <resource><directory>../common</directory><includes><include>icon.png</include></includes></resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>com.codenameone</groupId>
                <artifactId>codenameone-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>add-se-sources</id>
                        <phase>generate-sources</phase>
                        <goals><goal>generate-javase-sources</goal></goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration><release>17</release></configuration>
            </plugin>
        </plugins>
    </build>
    <profiles>
        <profile>
            <id>executable-jar</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-dependency-plugin</artifactId>
                        <version>3.6.1</version>
                        <executions>
                            <execution>
                                <id>copy-runtime</id>
                                <phase>prepare-package</phase>
                                <goals><goal>copy-dependencies</goal></goals>
                                <configuration>
                                    <outputDirectory>${project.build.directory}/libs</outputDirectory>
                                    <includeScope>runtime</includeScope>
                                    <overWriteSnapshots>true</overWriteSnapshots>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-jar-plugin</artifactId>
                        <version>3.3.0</version>
                        <configuration>
                            <archive>
                                <manifest><addClasspath>true</addClasspath><classpathPrefix>libs/</classpathPrefix><mainClass>com.codename1.videobuilder.VideoBuilderStub</mainClass></manifest>
                            </archive>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
