<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
    Project-specific SpotBugs exclusions for ByteCodeTranslator.

    ByteCodeTranslator is a build-time tool. The patterns below are scoped to the
    specific translator classes that exhibit them; framework-wide conventions
    inherited from core-unittests/spotbugs-exclude.xml are repeated here as well.
    -->

    <!-- Framework-wide conventions; see core-unittests/spotbugs-exclude.xml. -->
    <Match><Bug pattern="EI_EXPOSE_REP" /></Match>
    <Match><Bug pattern="EI_EXPOSE_REP2" /></Match>
    <Match><Bug pattern="EI_EXPOSE_STATIC_REP2" /></Match>
    <Match><Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" /></Match>

    <!--
    The translator is a command-line tool: System.exit() from the entry point
    is the intended shutdown path.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.ByteCodeTranslator(\$.*)?" />
        <Or>
            <Bug pattern="DM_EXIT" />
            <Bug pattern="DM_CONVERT_CASE" />
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
            <Bug pattern="MS_PKGPROTECT" />
            <Bug pattern="MS_SHOULD_BE_FINAL" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!--
    ByteCodeClass holds the global type model and writes static caches populated
    during a single translation run.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.ByteCodeClass(\$.*)?" />
        <Or>
            <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
            <Bug pattern="DM_CONVERT_CASE" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!--
    The translator's bytecode printer dispatches per-opcode through large switch
    statements; default cases are intentionally absent. Private fields cache
    static analysis data populated via visit callbacks.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.bytecodes\..*" />
        <Or>
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
            <Bug pattern="DB_DUPLICATE_BRANCHES" />
            <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS" />
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="URF_UNREAD_FIELD" />
        </Or>
    </Match>

    <!--
    BytecodeMethod hoists static tables that describe bytecode operands; the
    constructor callouts register the method with the type model.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.BytecodeMethod(\$.*)?" />
        <Or>
            <Bug pattern="EI_EXPOSE_STATIC_REP2" />
            <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="UCF_USELESS_CONTROL_FLOW" />
            <Bug pattern="UC_USELESS_VOID_METHOD" />
            <Bug pattern="URF_UNREAD_FIELD" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!-- ByteCodeField stores metadata collected during class visiting. -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.ByteCodeField(\$.*)?" />
        <Bug pattern="SF_SWITCH_NO_DEFAULT" />
    </Match>

    <!--
    TryCatch writes its module-scoped handler table from visit callbacks.
    -->
    <Match>
        <Class name="com.codename1.tools.translator.bytecodes.TryCatch" />
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
    </Match>

    <!-- LocalVariable intentionally rejects subtypes in equals(). -->
    <Match>
        <Class name="com.codename1.tools.translator.bytecodes.LocalVariable" />
        <Bug pattern="EQ_GETCLASS_AND_CLASS_CONSTANT" />
    </Match>

    <!-- Parser ingests input files and uses the same CLI-exit pattern. -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.Parser(\$.*)?" />
        <Or>
            <Bug pattern="DM_EXIT" />
            <Bug pattern="OS_OPEN_STREAM" />
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
        </Or>
    </Match>

    <!--
    JavascriptMethodGenerator emits the per-class JS module — uncalled
    private helpers are kept around for the conditional emission paths
    (peephole-passes, debug-trace flags) and the redundant null-checks /
    useless conditions match the same defensive pattern the existing
    translator classes use for visit-callback chains.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.JavascriptMethodGenerator(\$.*)?" />
        <Or>
            <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
            <Bug pattern="NP_NULL_ON_SOME_PATH" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="UC_USELESS_CONDITION" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
            <Bug pattern="DB_DUPLICATE_SWITCH_CLAUSES" />
            <Bug pattern="SF_SWITCH_NO_DEFAULT" />
        </Or>
    </Match>

    <!--
    JavascriptSuspensionAnalysis maintains the CHA worklist that decides
    which methods are emitted as ``function*``; the static-suspending
    set is intentionally written from instance methods because the
    analysis is single-threaded across one translator run.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.JavascriptSuspensionAnalysis(\$.*)?" />
        <Or>
            <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
            <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
            <Bug pattern="DLS_DEAD_LOCAL_STORE" />
        </Or>
    </Match>

    <!--
    JavascriptReachability tracks reachable-types analysis and uses
    per-opcode switch dispatch (duplicate cases mirror BytecodeMethod's
    pattern); the cached ``unreadField`` is populated lazily via reflection.
    -->
    <Match>
        <Class name="~com\.codename1\.tools\.translator\.JavascriptReachability(\$.*)?" />
        <Or>
            <Bug pattern="DB_DUPLICATE_SWITCH_CLAUSES" />
            <Bug pattern="URF_UNREAD_FIELD" />
        </Or>
    </Match>

    <!-- Util switch tables for VM type codes. -->
    <Match>
        <Class name="com.codename1.tools.translator.Util" />
        <Bug pattern="DB_DUPLICATE_SWITCH_CLAUSES" />
    </Match>

    <!-- ConcatenatingFileOutputStream streams to multiple files; bracket close in realClose. -->
    <Match>
        <Class name="com.codename1.tools.translator.ConcatenatingFileOutputStream" />
        <Or>
            <Bug pattern="OS_OPEN_STREAM_EXCEPTION_PATH" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
            <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
        </Or>
    </Match>

    <!-- JavascriptBundleWriter extracts packaged resources. -->
    <Match>
        <Class name="com.codename1.tools.translator.JavascriptBundleWriter" />
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
    </Match>
</FindBugsFilter>
